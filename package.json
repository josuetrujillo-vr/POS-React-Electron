{
  "name": "pos-vaquero",
  "version": "1.0.0",
  "description": "Sistema POS para local de ropa vaquera — offline-first con sincronización automática",
  "main": "out/main/index.js",
  "author": "Tu Negocio",
  "private": true,
  "scripts": {
    "dev": "concurrently -n app,api \"electron-vite dev\" \"node server-local/index.js\"",
    "dev:app": "electron-vite dev",
    "dev:api": "node server-local/index.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@node-escpos/core": "^0.6.0",
    "@node-escpos/network-adapter": "^0.0.1",
    "@node-escpos/usb-adapter": "^0.3.1",
    "axios": "^1.6.7",
    "idb": "^8.0.0",
    "lucide-react": "^1.23.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^10.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.posvaquero.app",
    "productName": "POS Vaquero",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
